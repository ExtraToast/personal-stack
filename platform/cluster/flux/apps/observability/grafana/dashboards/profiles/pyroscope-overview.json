{
  "uid": "pyroscope-overview",
  "title": "Profiles overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
        "query": "label_values(service_name)",
        "current": { "selected": true, "text": "auth-api", "value": "auth-api" }
      }
    ]
  },
  "panels": [
    {
      "type": "flamegraph",
      "title": "CPU flamegraph",
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service_name=\"$service\"}",
          "groupBy": [],
          "refId": "A"
        }
      ]
    },
    {
      "type": "flamegraph",
      "title": "Allocations flamegraph",
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "profileTypeId": "memory:alloc_in_new_tlab_bytes:bytes:space:bytes",
          "labelSelector": "{service_name=\"$service\"}",
          "groupBy": [],
          "refId": "A"
        }
      ]
    }
  ]
}
