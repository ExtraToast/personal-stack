{
  "uid": "gatus-uptime",
  "title": "Gatus uptime",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Endpoints failing now",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "count(gatus_results_endpoint_success == 0)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Uptime % per endpoint (24h / 7d / 30d)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "avg_over_time(gatus_results_endpoint_success[24h]) * 100",
          "legendFormat": "24h {{name}} {{group}}",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "avg_over_time(gatus_results_endpoint_success[7d]) * 100",
          "legendFormat": "7d {{name}} {{group}}",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "avg_over_time(gatus_results_endpoint_success[30d]) * 100",
          "legendFormat": "30d {{name}} {{group}}",
          "refId": "C",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Response time per endpoint (p95)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, name) (rate(gatus_results_endpoint_response_time_seconds_bucket[5m])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
