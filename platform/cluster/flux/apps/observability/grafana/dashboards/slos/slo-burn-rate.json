{
  "uid": "slo-burn-rate",
  "title": "SLO burn rate",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(traces_spanmetrics_calls_total, service_name)", "refId": "service" },
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      },
      {
        "name": "slo_target",
        "type": "constant",
        "current": { "text": "0.999", "value": "0.999" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Error rate (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\",status_code=\"STATUS_CODE_ERROR\"}[1h])) / sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[1h]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 0.1 } }
    },
    {
      "type": "timeseries",
      "title": "Fast burn (1h window, page if > 14.4)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "(sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\",status_code=\"STATUS_CODE_ERROR\"}[1h])) / sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[1h]))) / (1 - $slo_target)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Slow burn (6h window, ticket if > 1)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "(sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\",status_code=\"STATUS_CODE_ERROR\"}[6h])) / sum by (service_name) (rate(traces_spanmetrics_calls_total{service_name=~\"$service\"}[6h]))) / (1 - $slo_target)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 6 }
            ]
          }
        }
      }
    }
  ]
}
