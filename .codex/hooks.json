{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/kb-user-prompt-recall.sh\"",
            "timeout": 5,
            "statusMessage": "Loading KB context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/kb-stop-digest.sh\"",
            "timeout": 60,
            "statusMessage": "Capturing KB lessons"
          }
        ]
      }
    ]
  }
}
