;;
;; Domain:     jorisjonkers.dev.
;;
;; Cloudflare-importable zone file for jorisjonkers.dev.
;; Covers the root domain and all subdomains via wildcard CNAME.
;;
;; Records:
;;   A/AAAA  jorisjonkers.dev         → Contabo VPS (167.86.79.203 / 2a02:c207:2318:569::1), proxied
;;   CNAME   *.jorisjonkers.dev       → jorisjonkers.dev, proxied
;;   A/AAAA  mail.jorisjonkers.dev    → Contabo VPS, NOT proxied (mail needs direct IP)
;;   A       jellyfin.jorisjonkers.dev → home WAN IP (130.89.169.227), NOT proxied
;;   MX      jorisjonkers.dev         → mail.jorisjonkers.dev
;;
;; Subdomains in use (all resolved via wildcard CNAME unless listed as an exception):
;;   auth.jorisjonkers.dev
;;   assistant.jorisjonkers.dev
;;   vault.jorisjonkers.dev
;;   n8n.jorisjonkers.dev
;;   grafana.jorisjonkers.dev
;;   status.jorisjonkers.dev
;;   traefik.jorisjonkers.dev
;;   stalwart.jorisjonkers.dev
;;   mail.jorisjonkers.dev     (explicit A, not proxied — SMTP/IMAP need direct IP)
;;   jellyfin.jorisjonkers.dev (explicit A, not proxied — grey-cloud so WAN clients
;;                              hit the home router directly, bypassing the VPS and
;;                              Cloudflare's video-streaming ToS §2.8. LAN clients
;;                              get 192.168.0.99 via AdGuard split-horizon DNS.)

;; A Records
jorisjonkers.dev.    1    IN    A    167.86.79.203 ; cf_tags=cf-proxied:true

;; AAAA Records
jorisjonkers.dev.    1    IN    AAAA    2a02:c207:2318:569::1 ; cf_tags=cf-proxied:true

;; CNAME Records
*.jorisjonkers.dev.    1    IN    CNAME    jorisjonkers.dev. ; cf_tags=cf-proxied:true

;; ── Mail Server ─────────────────────────────────────────────────────────────
;; mail.jorisjonkers.dev must NOT be Cloudflare-proxied (SMTP/IMAP need direct IP)
;; Only publish AAAA once IPv6 has been validated end-to-end for HTTPS and mail protocols.
mail.jorisjonkers.dev.    1    IN    A       167.86.79.203 ; cf_tags=cf-proxied:false

;; ── Home-Direct Services ────────────────────────────────────────────────────
;; Specific records here override the wildcard CNAME. Used for workloads where
;; the VPS hop or CF proxying is counterproductive (bulk video streaming).
;; The home WAN IP is static per the ISP. Router forwards :443 to
;; traefik-lan on 192.168.0.99. Must NOT be proxied: CF edge can't reach
;; 130.89.169.227 as an origin, and CF's self-serve §2.8 forbids streaming
;; video through their proxy anyway.
jellyfin.jorisjonkers.dev.    1    IN    A       130.89.169.227 ; cf_tags=cf-proxied:false

;; MX Record
jorisjonkers.dev.    1    IN    MX    10 mail.jorisjonkers.dev.

;; SPF — only the MX server may send mail for this domain
jorisjonkers.dev.    1    IN    TXT    "v=spf1 mx -all"
mail.jorisjonkers.dev.    1    IN    TXT    "v=spf1 a -all"

;; DMARC — quarantine policy; upgrade to p=reject after one clean week
_dmarc.jorisjonkers.dev.    1    IN    TXT    "v=DMARC1; p=quarantine; rua=mailto:postmaster@jorisjonkers.dev; fo=1"

;; DKIM — ed25519 + RSA dual signing
202604e._domainkey.jorisjonkers.dev.    1    IN    TXT    "v=DKIM1; k=ed25519; h=sha256; p=4Ki5wXjYI1M33WGOHV6DKY2MMlX953wP4MH6hn+ek8w="
202604r._domainkey.jorisjonkers.dev.    1    IN    TXT    "v=DKIM1; k=rsa; h=sha256; "
