;; Cloudflare-importable zone file for jorisjonkers.dev.
;; Covers the root domain and all subdomains via wildcard CNAME.
;;
;; Records:
;;   A/AAAA  jorisjonkers.dev      → Contabo VPS (167.86.79.203 / 2a02:c207:2318:569::1), proxied
;;   CNAME   *.jorisjonkers.dev    → jorisjonkers.dev, proxied
;;
;; Subdomains in use (all resolved via wildcard CNAME):
;;   auth.jorisjonkers.dev
;;   assistant.jorisjonkers.dev
;;   vault.jorisjonkers.dev
;;   n8n.jorisjonkers.dev
;;   grafana.jorisjonkers.dev
;;   status.jorisjonkers.dev
;;   traefik.jorisjonkers.dev

;; A Records
jorisjonkers.dev.    1    IN    A    167.86.79.203 ; cf_tags=cf-proxied:true

;; AAAA Records
jorisjonkers.dev.    1    IN    AAAA    2a02:c207:2318:569::1 ; cf_tags=cf-proxied:true

;; CNAME Records
*.jorisjonkers.dev.    1    IN    CNAME    jorisjonkers.dev. ; cf_tags=cf-proxied:true