{
  "uid": "tempo-traces",
  "title": "Tempo / Traces",
  "tags": ["tempo", "traces", "opentelemetry"],
  "timezone": "browser",
  "editable": false,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "query": "auth-api,assistant-api",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "min_duration",
        "type": "custom",
        "query": "100ms,500ms,1s,5s",
        "current": { "text": "100ms", "value": "100ms" },
        "label": "Min Duration"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Trace Search",
      "type": "traces",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "query": "{resource.service.name=~\"$service\" && duration > $min_duration}",
          "limit": 20
        }
      ],
      "datasource": { "type": "tempo", "uid": "tempo" }
    },
    {
      "id": 2,
      "title": "Service Graph",
      "type": "nodeGraph",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "serviceMap"
        }
      ],
      "datasource": { "type": "tempo", "uid": "tempo" }
    },
    {
      "id": 3,
      "title": "Span Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum by(service_name)(rate(traces_spanmetrics_calls_total[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 4,
      "title": "Span Duration P95 by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le, service_name)(rate(traces_spanmetrics_latency_bucket[5m])))",
          "legendFormat": "{{service_name}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 5,
      "title": "Error Spans",
      "type": "traces",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "query": "{resource.service.name=~\"$service\" && status = error}",
          "limit": 20
        }
      ],
      "datasource": { "type": "tempo", "uid": "tempo" }
    },
    {
      "id": 6,
      "title": "Span Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "sum by(service_name)(rate(traces_spanmetrics_calls_total{status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "legendFormat": "{{service_name}} errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 7,
      "title": "Span Duration P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le)(rate(traces_spanmetrics_latency_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le)(rate(traces_spanmetrics_latency_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le)(rate(traces_spanmetrics_latency_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    }
  ],
  "schemaVersion": 39
}
