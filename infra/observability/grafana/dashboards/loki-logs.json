{
  "uid": "loki-logs",
  "title": "Loki / Logs",
  "tags": ["loki", "logs"],
  "timezone": "browser",
  "editable": false,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({container=~\".+\"}, container)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "level",
        "type": "custom",
        "query": "DEBUG,INFO,WARN,ERROR",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "label": "Search"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(container)(count_over_time({container=~\"$container\"}[5m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Log Rate by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(container)(count_over_time({container=~\"$container\"} | json | level=\"ERROR\" [5m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 3,
      "title": "Log Level Distribution (1h)",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(level)(count_over_time({container=~\"$container\"} | json | level=~\".+\" [1h]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARN" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DEBUG" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "Warn + Error Ratio",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container=~\"$container\"} | json | level=~\"WARN|ERROR\" [1h])) / sum(count_over_time({container=~\"$container\"} [1h])) * 100",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "Top Error Messages (1h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(10, sum by(message)(count_over_time({container=~\"$container\"} | json | level=\"ERROR\" [1h])))",
          "legendFormat": "{{message}}",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Log Stream",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"$container\"} | json | level=~\"$level\" |~ \"$search\"",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 7,
      "title": "Logs with Trace ID",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=~\"$container\"} | json | traceId != \"\"",
          "maxLines": 100
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39
}
