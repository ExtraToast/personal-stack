{
  "uid": "traefik",
  "title": "Traefik",
  "tags": ["traefik", "reverse-proxy"],
  "timezone": "browser",
  "editable": false,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "entrypoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(traefik_entrypoint_requests_total, entrypoint)",
        "current": { "text": "websecure", "value": "websecure" },
        "refresh": 2
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(traefik_service_requests_total, service)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests/s",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(traefik_entrypoint_requests_total{entrypoint=\"$entrypoint\"}[5m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 2,
      "title": "4xx Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(traefik_entrypoint_requests_total{entrypoint=\"$entrypoint\", code=~\"4..\"}[5m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 3,
      "title": "5xx Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(traefik_entrypoint_requests_total{entrypoint=\"$entrypoint\", code=~\"5..\"}[5m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 4,
      "title": "Open Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(traefik_entrypoint_open_connections{entrypoint=\"$entrypoint\"})",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 5,
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by(service)(rate(traefik_service_requests_total[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 6,
      "title": "Response Status by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum by(service, code)(rate(traefik_service_requests_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}} - {{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 7,
      "title": "Latency P50 / P95 / P99 by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le, service)(rate(traefik_service_request_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{{service}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le, service)(rate(traefik_service_request_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{{service}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le, service)(rate(traefik_service_request_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{{service}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 8,
      "title": "Request Duration Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by(le)(rate(traefik_service_request_duration_seconds_bucket{service=~\"$service\"}[5m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges" }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 9,
      "title": "TLS Certificate Expiry",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "(traefik_tls_certs_not_after - time()) / 86400",
          "legendFormat": "{{cn}} ({{sans}}) days remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 14 },
              { "color": "green", "value": 30 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "id": 10,
      "title": "Requests by Entrypoint",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum by(entrypoint)(rate(traefik_entrypoint_requests_total[5m]))",
          "legendFormat": "{{entrypoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39
}
