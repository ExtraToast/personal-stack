datacenter = "dc1"
data_dir   = "/opt/nomad"
bind_addr  = "0.0.0.0"
region     = "global"

server {
  enabled          = true
  bootstrap_expect = 1
}

client {
  enabled = true
}

acl {
  enabled = true
}

consul {
  address = "127.0.0.1:8500"
}

vault {
  enabled = true
  address = "http://127.0.0.1:8200"

  default_identity {
    aud = ["vault.io"]
    ttl = "1h"
  }
}
