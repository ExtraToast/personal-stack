# Contabo API credentials (from customer control panel)
CONTABO_OAUTH2_CLIENT_ID=
CONTABO_OAUTH2_CLIENT_SECRET=
CONTABO_OAUTH2_USER=
CONTABO_OAUTH2_PASSWORD=

# Contabo VPS identifiers
CONTABO_INSTANCE_ID=
CONTABO_IMAGE_ID=

# Contabo secret ID for the SSH key (auto-filled by provision.sh on first run)
CONTABO_SSH_SECRET_ID=

# GitHub repository (SSH clone URL)
GITHUB_REPO=git@github.com:ExtraToast/private-stack.git

# GitHub Container Registry (PAT with read:packages scope)
GHCR_USER=ExtraToast
GHCR_TOKEN=

# Docker Swarm secrets — auto-generated on first run if left empty
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
RABBITMQ_USER=appuser
RABBITMQ_PASSWORD=
CF_DNS_API_TOKEN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=
