# Contabo API credentials (from customer control panel)
CONTABO_OAUTH2_CLIENT_ID=
CONTABO_OAUTH2_CLIENT_SECRET=
CONTABO_OAUTH2_USER=
CONTABO_OAUTH2_PASSWORD=

# Contabo VPS identifiers
CONTABO_INSTANCE_ID=
CONTABO_IMAGE_ID=

# Contabo secret ID for the SSH key (auto-filled by provision.sh on first run)
CONTABO_SSH_SECRET_ID=

# GitHub repository (SSH clone URL)
GITHUB_REPO=git@github.com:ExtraToast/personal-stack.git

# GitHub Container Registry (PAT with read:packages scope)
GHCR_USER=ExtraToast
GHCR_TOKEN=
IMAGE_TAG=latest

# Platform bootstrap values
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
RABBITMQ_USER=appuser
RABBITMQ_PASSWORD=
CF_DNS_API_TOKEN=
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=
ASSISTANT_DB_USER=assistant_user
ASSISTANT_DB_PASSWORD=
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=

# Optional OAuth client secrets; generated on first server bootstrap when blank
N8N_OAUTH_CLIENT_SECRET=
GRAFANA_OAUTH_CLIENT_SECRET=
VAULT_OIDC_CLIENT_SECRET=
STALWART_OAUTH_CLIENT_SECRET=
