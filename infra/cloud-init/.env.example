# Contabo API credentials (from customer control panel)
CONTABO_OAUTH2_CLIENT_ID=
CONTABO_OAUTH2_CLIENT_SECRET=
CONTABO_OAUTH2_USER=
CONTABO_OAUTH2_PASSWORD=

# Contabo VPS identifiers
CONTABO_INSTANCE_ID=
CONTABO_IMAGE_ID=

# Contabo secret ID for the SSH key (auto-filled by provision.sh on first run)
CONTABO_SSH_SECRET_ID=

# GitHub repository (SSH clone URL)
GITHUB_REPO=git@github.com:ExtraToast/private-stack.git
